<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="description" content="Fabricio Martínez — Consultoría de Inmersión Profunda. Neurociencias aplicadas al alto rendimiento organizacional.">
<title>Fabricio Martínez</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --gold:#D4AF37;
  --gold-dim:rgba(212,175,55,0.12);
  --gold-border:rgba(212,175,55,0.3);
  --dark:#08090E;
  --dark-2:#0F1119;
  --dark-3:#161A24;
  --dark-4:#1D2130;
  --text:#EEF0F7;
  --muted:#5A6070;
  --dim:#30354A;
  --border:rgba(255,255,255,0.06);
}
html{scroll-behavior:smooth;background:var(--dark);}
body{
  font-family:'Inter',sans-serif;
  background:var(--dark);
  color:var(--text);
  min-height:100vh;
  max-width:480px;
  margin:0 auto;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
 
/* ── SCREENS ── */
.screen{display:none;min-height:100vh;flex-direction:column;}
.screen.active{display:flex;}
 
/* ── HOME ── */
#screen-home{
  background:radial-gradient(ellipse at 50% 0%, rgba(212,175,55,0.08) 0%, transparent 65%), var(--dark);
  padding:0;
}
.home-header{
  padding:48px 28px 32px;
  text-align:center;
  border-bottom:1px solid var(--border);
}
.avatar-ring{
  width:88px;height:88px;
  border-radius:50%;
  border:1.5px solid var(--gold-border);
  padding:3px;
  margin:0 auto 16px;
}
.avatar-ring img{
  width:100%;height:100%;
  border-radius:50%;
  object-fit:cover;
  filter:grayscale(30%);
}
.avatar-initials{
  width:100%;height:100%;
  border-radius:50%;
  background:var(--dark-3);
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;font-weight:900;color:var(--gold);
  letter-spacing:-0.02em;
}
.home-name{
  font-size:1.25rem;font-weight:900;
  letter-spacing:-0.01em;
  text-transform:uppercase;
  margin-bottom:4px;
}
.home-title{
  font-size:0.62rem;font-weight:500;
  letter-spacing:0.28em;text-transform:uppercase;
  color:var(--gold);margin-bottom:8px;
}
.home-bio{
  font-size:0.8rem;color:var(--muted);
  line-height:1.6;max-width:280px;margin:0 auto;
  font-style:italic;
}
 
/* ── TABS ── */
.tabs{
  display:grid;grid-template-columns:repeat(3,1fr);
  border-bottom:1px solid var(--border);
  background:var(--dark-2);
  position:sticky;top:0;z-index:10;
}
.tab-btn{
  padding:14px 4px;
  font-size:0.55rem;font-weight:700;
  letter-spacing:0.15em;text-transform:uppercase;
  color:var(--muted);background:transparent;border:none;cursor:pointer;
  border-bottom:2px solid transparent;
  transition:color 0.2s,border-color 0.2s;
  display:flex;flex-direction:column;align-items:center;gap:5px;
  font-family:'Inter',sans-serif;
}
.tab-btn i{font-size:0.9rem;}
.tab-btn.active{color:var(--gold);border-bottom-color:var(--gold);}
 
/* ── TAB PANELS ── */
.tab-panel{display:none;padding:24px 20px 48px;flex:1;}
.tab-panel.active{display:block;}
 
/* ── SERVICIOS ── */
.service-card{
  background:var(--dark-2);
  border:1px solid var(--border);
  border-radius:16px;
  padding:20px;
  margin-bottom:12px;
  display:flex;align-items:flex-start;gap:14px;
  transition:border-color 0.2s;
  cursor:default;
}
.service-card:active{border-color:var(--gold-border);}
.service-icon{
  width:40px;height:40px;flex-shrink:0;
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;
}
.service-body h3{
  font-size:0.75rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  margin-bottom:4px;
}
.service-body p{font-size:0.75rem;color:var(--muted);line-height:1.55;}
.stat-strip{
  display:grid;grid-template-columns:repeat(2,1fr);
  gap:10px;margin:20px 0;
}
.stat-box{
  background:var(--dark-2);border:1px solid var(--border);
  border-radius:12px;padding:16px 14px;text-align:center;
}
.stat-box .num{
  font-size:1.8rem;font-weight:900;color:var(--gold);
  display:block;line-height:1;margin-bottom:4px;
}
.stat-box .lbl{
  font-size:0.55rem;font-weight:700;
  letter-spacing:0.18em;text-transform:uppercase;color:var(--muted);
}
.section-label{
  font-size:0.58rem;font-weight:700;
  letter-spacing:0.3em;text-transform:uppercase;
  color:var(--gold);margin-bottom:14px;display:block;
}
.creds-list{margin-top:20px;}
.cred-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 0;border-bottom:1px solid var(--border);
  font-size:0.72rem;color:var(--muted);
}
.cred-item i{color:var(--gold);font-size:0.6rem;flex-shrink:0;}
.iso-wrap{
  background:var(--dark-2);border:1px solid var(--border);
  border-radius:16px;padding:18px;margin-top:12px;
}
.iso-wrap p{font-size:0.72rem;color:var(--muted);line-height:1.55;margin-bottom:12px;}
.iso-tags{display:flex;flex-wrap:wrap;gap:6px;}
.iso-tag{
  font-size:0.55rem;font-weight:700;
  letter-spacing:0.12em;text-transform:uppercase;
  padding:5px 10px;border-radius:20px;
  border:1px solid var(--gold-border);color:var(--gold);
}
 
/* ── CTA BUTTONS ── */
.btn-gold{
  display:block;width:100%;
  padding:16px;text-align:center;
  background:var(--gold);color:#08090E;
  font-size:0.65rem;font-weight:700;
  letter-spacing:0.25em;text-transform:uppercase;
  border-radius:10px;border:none;cursor:pointer;
  text-decoration:none;
  font-family:'Inter',sans-serif;
  transition:background 0.2s,transform 0.1s;
  margin-bottom:10px;
}
.btn-gold:active{transform:scale(0.98);background:#e8c96b;}
.btn-outline{
  display:block;width:100%;
  padding:16px;text-align:center;
  background:transparent;color:var(--text);
  font-size:0.65rem;font-weight:700;
  letter-spacing:0.2em;text-transform:uppercase;
  border-radius:10px;border:1px solid var(--border);
  cursor:pointer;text-decoration:none;
  font-family:'Inter',sans-serif;
  transition:border-color 0.2s;
  margin-bottom:10px;
}
.btn-outline:active{border-color:var(--gold-border);}
.socials-row{
  display:flex;justify-content:center;gap:20px;
  margin-top:24px;
}
.social-btn{
  width:48px;height:48px;
  border-radius:12px;
  background:var(--dark-2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  color:var(--muted);font-size:1.1rem;
  text-decoration:none;transition:border-color 0.2s,color 0.2s;
}
.social-btn:active{border-color:var(--gold-border);color:var(--gold);}
 
/* ── RADAR ── */
.radar-intro{
  font-size:0.75rem;color:var(--muted);
  line-height:1.6;margin-bottom:20px;
  font-style:italic;text-align:center;
}
.r-dim-row{margin-bottom:16px;}
.r-dim-header{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:6px;
}
.r-dim-name{
  font-size:0.62rem;font-weight:700;
  letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);
}
.r-dim-val{font-size:0.72rem;font-weight:700;color:var(--gold);}
input[type=range]{
  -webkit-appearance:none;appearance:none;
  width:100%;height:3px;
  background:rgba(212,175,55,0.2);
  border-radius:2px;cursor:pointer;outline:none;
}
input[type=range]::-webkit-slider-thumb{
  -webkit-appearance:none;
  width:18px;height:18px;
  background:var(--gold);border-radius:50%;border:none;
}
input[type=range]::-moz-range-thumb{
  width:18px;height:18px;
  background:var(--gold);border-radius:50%;border:none;
}
.r-metrics-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:20px 0;}
.r-metric{
  background:var(--dark-2);border:1px solid var(--border);
  border-radius:12px;padding:12px 8px;text-align:center;
}
.r-metric .val{
  font-size:1.4rem;font-weight:900;color:var(--gold);
  display:block;line-height:1;margin-bottom:4px;
}
.r-metric .lbl{font-size:0.52rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);}
.r-metric .sub{font-size:0.6rem;color:var(--dim);margin-top:2px;}
.r-nivel{
  display:inline-block;
  font-size:0.55rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;
  padding:5px 12px;border-radius:4px;margin-bottom:16px;
}
.chart-wrap{display:flex;justify-content:center;margin:8px 0 20px;}
.r-btn-row{display:flex;gap:8px;}
.r-btn-reset{
  padding:14px 16px;
  border:1px solid var(--border);background:transparent;
  color:var(--muted);font-size:0.6rem;font-weight:700;
  letter-spacing:0.15em;text-transform:uppercase;
  border-radius:10px;cursor:pointer;font-family:'Inter',sans-serif;
  transition:border-color 0.2s;flex-shrink:0;
}
.r-btn-reset:active{border-color:var(--gold-border);}
 
/* ── DIAGNÓSTICO ── */
.d-progress-bg{height:2px;background:var(--border);border-radius:1px;margin-bottom:24px;}
.d-progress-fill{height:2px;background:var(--gold);border-radius:1px;transition:width 0.4s ease;}
.d-step{display:none;}
.d-step.active{display:block;}
.d-meta{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:6px;
}
.d-meta span{font-size:0.55rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--dim);}
.d-area-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:20px;}
.d-area-btn{
  padding:22px 8px;
  border:1px solid var(--border);background:var(--dark-2);
  color:var(--muted);border-radius:14px;cursor:pointer;
  text-align:center;transition:all 0.2s;font-family:'Inter',sans-serif;
}
.d-area-btn.selected{border-color:var(--gold);color:var(--gold);background:var(--gold-dim);}
.d-area-btn i{font-size:1.2rem;display:block;margin-bottom:8px;}
.d-area-btn span{font-size:0.55rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;display:block;}
.d-dim-label{
  font-size:0.58rem;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;
  color:var(--gold);display:block;margin-bottom:8px;
}
.d-question{
  font-size:0.95rem;font-weight:700;
  text-transform:uppercase;letter-spacing:-0.01em;
  line-height:1.35;margin-bottom:20px;
  font-style:italic;
}
.d-opts{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.d-opt{
  width:100%;padding:13px 16px;
  border:1px solid var(--border);background:var(--dark-2);
  color:var(--muted);border-radius:10px;cursor:pointer;
  text-align:left;font-size:0.78rem;line-height:1.45;
  transition:all 0.15s;font-family:'Inter',sans-serif;display:block;
}
.d-opt.selected{border-color:var(--gold);color:var(--gold);background:var(--gold-dim);}
.d-nav{display:flex;gap:8px;}
.d-btn-back{
  padding:14px 16px;
  border:1px solid var(--border);background:transparent;
  color:var(--muted);font-size:0.6rem;font-weight:700;
  letter-spacing:0.15em;text-transform:uppercase;
  border-radius:10px;cursor:pointer;font-family:'Inter',sans-serif;
  flex-shrink:0;
}
.d-btn-next{
  flex:1;padding:14px;
  background:var(--gold);color:#08090E;
  font-size:0.6rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;
  border-radius:10px;border:none;cursor:pointer;
  font-family:'Inter',sans-serif;transition:opacity 0.2s,background 0.2s;
}
.d-btn-next:disabled{opacity:0.2;cursor:default;}
.d-btn-next:not(:disabled):active{background:#e8c96b;}
/* result */
.d-score-big{
  font-size:4.5rem;font-weight:900;line-height:1;
  text-align:center;margin-bottom:8px;
}
.d-nivel-badge{
  display:inline-block;font-size:0.55rem;font-weight:700;
  letter-spacing:0.2em;text-transform:uppercase;
  padding:5px 14px;border-radius:4px;
}
.d-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.d-bar-label{font-size:0.6rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);width:110px;flex-shrink:0;}
.d-bar-bg{flex:1;height:4px;background:var(--border);border-radius:2px;overflow:hidden;}
.d-bar-fill{height:4px;border-radius:2px;transition:width 1.1s ease;}
.d-bar-val{font-size:0.6rem;font-weight:700;color:var(--muted);width:28px;text-align:right;}
.d-reco{
  border-left:2px solid var(--gold);
  padding:10px 14px;margin-bottom:8px;
  background:rgba(212,175,55,0.04);
  font-size:0.75rem;color:var(--muted);line-height:1.65;
}
 
/* ── BOTTOM SAFE AREA ── */
.bottom-safe{height:env(safe-area-inset-bottom,16px);}
 
/* ── KEYFRAMES ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}
.anim{animation:fadeUp 0.4s ease forwards;}
</style>
</head>
<body>
 
<!-- ═══════════════ HOME SCREEN ═══════════════ -->
