  <!-- ── TAB: RADAR ── -->
  <div class="tab-panel" id="tab-radar">
    <span class="section-label">Radar de madurez organizacional</span>
    <p class="radar-intro">Mové cada slider según tu realidad actual y mirá tu perfil al instante.</p>
 
    <div style="text-align:center;margin-bottom:16px;">
