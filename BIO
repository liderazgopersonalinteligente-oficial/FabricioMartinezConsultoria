    <div class="d-step active" id="ds-0">
      <div class="d-area-grid" id="d-area-grid"></div>
      <button class="d-btn-next" id="d-next-0" disabled onclick="dNext()" style="width:100%;">Continuar →</button>
    </div>
    <!-- steps 1-5 -->
    <div class="d-step" id="ds-1"><span class="d-dim-label" id="d-dlabel-1"></span><p class="d-question" id="d-q-1"></p><div class="d-opts" id="d-opts-1"></div><div class="d-nav"><button class="d-btn-back" onclick="dBack()">← Atrás</button><button class="d-btn-next" id="d-next-1" disabled onclick="dNext()">Continuar →</button></div></div>
    <div class="d-step" id="ds-2"><span class="d-dim-label" id="d-dlabel-2"></span><p class="d-question" id="d-q-2"></p><div class="d-opts" id="d-opts-2"></div><div class="d-nav"><button class="d-btn-back" onclick="dBack()">← Atrás</button><button class="d-btn-next" id="d-next-2" disabled onclick="dNext()">Continuar →</button></div></div>
    <div class="d-step" id="ds-3"><span class="d-dim-label" id="d-dlabel-3"></span><p class="d-question" id="d-q-3"></p><div class="d-opts" id="d-opts-3"></div><div class="d-nav"><button class="d-btn-back" onclick="dBack()">← Atrás</button><button class="d-btn-next" id="d-next-3" disabled onclick="dNext()">Continuar →</button></div></div>
    <div class="d-step" id="ds-4"><span class="d-dim-label" id="d-dlabel-4"></span><p class="d-question" id="d-q-4"></p><div class="d-opts" id="d-opts-4"></div><div class="d-nav"><button class="d-btn-back" onclick="dBack()">← Atrás</button><button class="d-btn-next" id="d-next-4" disabled onclick="dNext()">Continuar →</button></div></div>
    <div class="d-step" id="ds-5"><span class="d-dim-label" id="d-dlabel-5"></span><p class="d-question" id="d-q-5"></p><div class="d-opts" id="d-opts-5"></div><div class="d-nav"><button class="d-btn-back" onclick="dBack()">← Atrás</button><button class="d-btn-next" id="d-next-5" disabled onclick="dNext()">Ver resultado →</button></div></div>
    <!-- result -->
    <div class="d-step" id="ds-6"><div id="d-result"></div></div>
  </div>
 
  <div class="bottom-safe"></div>
</div>
 
<script>
/* ════════════════════════════════
   TABS
════════════════════════════════ */
function showTab(name) {
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    const tabs=['servicios','radar','diagnostico'];
    b.classList.toggle('active', tabs[i]===name);
  });
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='radar' && !rChart) buildRadarChart();
}
 
/* ════════════════════════════════
   RADAR
════════════════════════════════ */
const rDims=[
  {key:'liderazgo',    label:'Liderazgo'},
  {key:'comunicacion', label:'Comunicación'},
  {key:'okr',          label:'OKRs / Estrategia'},
  {key:'clima',        label:'Clima / Cultura'},
  {key:'decision',     label:'Decisiones'},
  {key:'procesos',     label:'Calidad'},
];
const rVals={}; rDims.forEach(d=>rVals[d.key]=5);
 
(function buildSliders(){
  const c=document.getElementById('r-sliders-container');
  rDims.forEach(d=>{
    const div=document.createElement('div'); div.className='r-dim-row';
    div.innerHTML=`<div class="r-dim-header"><span class="r-dim-name">${d.label}</span><span class="r-dim-val" id="rv-${d.key}">5</span></div>
    <input type="range" min="1" max="10" step="1" value="5" oninput="rSlide('${d.key}',this.value)">`;
    c.appendChild(div);
  });
})();
 
function rSlide(key,v){
  rVals[key]=parseInt(v);
  document.getElementById('rv-'+key).textContent=v;
  rUpdateMetrics();
  if(rChart) rUpdateChart();
}
function rUpdateMetrics(){
  const vals=rDims.map(d=>rVals[d.key]);
  const g=Math.round((vals.reduce((a,b)=>a+b,0)/(rDims.length*10))*100);
  document.getElementById('r-global-val').textContent=g+'%';
  let best=rDims[0],worst=rDims[0];
  rDims.forEach(d=>{if(rVals[d.key]>rVals[best.key])best=d;if(rVals[d.key]<rVals[worst.key])worst=d;});
  document.getElementById('r-best-name').textContent=best.label;
  document.getElementById('r-best-sub').textContent=rVals[best.key]+'/10';
  document.getElementById('r-worst-name').textContent=worst.label;
  document.getElementById('r-worst-sub').textContent=rVals[worst.key]+'/10';
  let nivel,bg,color;
  if(g<=35)     {nivel='Estadio inicial';         bg='rgba(163,45,45,0.18)'; color='#F09595';}
  else if(g<=55){nivel='En desarrollo';           bg='rgba(186,117,23,0.18)';color='#EF9F27';}
  else if(g<=75){nivel='Alto rendimiento parcial';bg='rgba(55,138,221,0.18)';color='#85B7EB';}
  else          {nivel='Excelencia';              bg='rgba(212,175,55,0.18)'; color='#D4AF37';}
  const b=document.getElementById('r-nivel');
  b.textContent=nivel;b.style.background=bg;b.style.color=color;
  b.style.padding='5px 14px';b.style.borderRadius='4px';
}
let rChart=null;
function buildRadarChart(){
  const ctx=document.getElementById('radarChart').getContext('2d');
  rChart=new Chart(ctx,{
    type:'radar',
    data:{
      labels:rDims.map(d=>d.label),
      datasets:[
        {label:'Tu organización',data:rDims.map(d=>rVals[d.key]),
         backgroundColor:'rgba(212,175,55,0.13)',borderColor:'#D4AF37',
         borderWidth:2,pointBackgroundColor:'#D4AF37',pointRadius:4,pointHoverRadius:6},
        {label:'Referencia',data:rDims.map(()=>8),
         backgroundColor:'rgba(255,255,255,0.02)',borderColor:'rgba(255,255,255,0.1)',
         borderWidth:1.5,borderDash:[5,5],pointRadius:0}
      ]
    },
    options:{
      responsive:false,
      plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(8,9,14,0.95)',titleColor:'#D4AF37',bodyColor:'#94a3b8',borderColor:'rgba(212,175,55,0.2)',borderWidth:1}},
      scales:{r:{
        min:0,max:10,
        ticks:{stepSize:2,color:'rgba(255,255,255,0.12)',font:{size:9},backdropColor:'transparent'},
        grid:{color:'rgba(255,255,255,0.05)'},
        angleLines:{color:'rgba(255,255,255,0.05)'},
        pointLabels:{color:'rgba(148,163,184,0.55)',font:{size:10}}
      }}
    }
  });
  rUpdateMetrics();
}
function rUpdateChart(){rChart.data.datasets[0].data=rDims.map(d=>rVals[d.key]);rChart.update('none');}
function rReset(){
  rDims.forEach(d=>{rVals[d.key]=5;document.querySelector(`input[oninput*="${d.key}"]`).value=5;document.getElementById('rv-'+d.key).textContent=5;});
  rUpdateMetrics();if(rChart)rUpdateChart();
}
 
/* ════════════════════════════════
   DIAGNÓSTICO
════════════════════════════════ */
const dQs={
  empresa:[
    {dim:'OKR',q:'¿Qué tan alineados están los equipos con los objetivos estratégicos?',opts:[['Sin alineación formal',1],['Alineación parcial e inconsistente',2],['Mayoría alineada, algunos focos dispersos',3],['Alta alineación con revisión periódica',4]]},
    {dim:'Liderazgo',q:'¿Cómo es la toma de decisiones bajo presión?',opts:[['Reactiva, sin protocolo claro',1],['Depende de quién esté a cargo',2],['Protocolo existe pero no siempre se aplica',3],['Toma de decisiones estructurada y efectiva',4]]},
    {dim:'Comunicación',q:'¿El ruido interno afecta la productividad?',opts:[['A diario, problema crónico',1],['Varias veces por semana',2],['Ocasionalmente',3],['Rara vez, canales bien definidos',4]]},
    {dim:'Clima',q:'¿Cómo es la energía y motivación del equipo?',opts:[['Baja, hay desgaste y rotación',1],['Variable según área o líder',2],['Aceptable, con potencial de mejora',3],['Alta, equipo comprometido',4]]},
    {dim:'Calidad',q:'¿Tenés procesos de calidad certificados?',opts:[['No, trabajamos de forma empírica',1],['Hay intención sin avance concreto',2],['En proceso de implementación',3],['Certificados y auditados regularmente',4]]},
  ],
  deporte:[
    {dim:'Presión',q:'¿Cómo responde el equipo ante alta presión competitiva?',opts:[['Se bloquea o pierde eficacia',1],['Respuesta inconsistente',2],['Bien en la mayoría de los casos',3],['Sólido y predecible bajo presión máxima',4]]},
    {dim:'Liderazgo',q:'¿Cómo es el liderazgo dentro del equipo?',opts:[['Ausente o generador de conflictos',1],['Informal y no estructurado',2],['Un líder claro sin apoyo sistémico',3],['Liderazgo distribuido y funcional',4]]},
    {dim:'Cognitivo',q:'¿Existe entrenamiento cognitivo-motor específico?',opts:[['No, solo trabajo físico-técnico',1],['Esporádico, sin metodología',2],['Incorporado pero no sistematizado',3],['Programa estructurado y medido',4]]},
    {dim:'Clima',q:'¿Cómo es la cohesión y clima grupal?',opts:[['Tensiones frecuentes, poca confianza',1],['Inestable, varía por resultados',2],['Buena base con focos de mejora',3],['Alta cohesión y confianza grupal',4]]},
    {dim:'Gestión',q:'¿Cómo es la gestión administrativa del club?',opts:[['Sin estructura formal',1],['Básica, muchos procesos informales',2],['Estructura parcial con algunos sistemas',3],['Gestión profesional con indicadores',4]]},
  ],
  organismo:[
    {dim:'Clima',q:'¿Cómo es el clima general de la institución?',opts:[['Conflictivo, resistencia al cambio',1],['Tenso pero manejable',2],['Neutro, sin compromiso ni conflicto',3],['Positivo y orientado a la mejora',4]]},
    {dim:'Conducción',q:'¿Con qué claridad se ejerce la conducción?',opts:[['Sin dirección clara, mucha improvisación',1],['Genera contradicciones frecuentes',2],['Aceptable con áreas de mejora',3],['Liderazgo claro, estratégico y coherente',4]]},
    {dim:'Comunicación',q:'¿Cómo fluye la información entre niveles?',opts:[['Obstruida, con silos y rumores',1],['Lenta e inconsistente',2],['Fluye con pérdida de calidad',3],['Clara, oportuna y bidireccional',4]]},
    {dim:'Procesos',q:'¿Existen procesos documentados y protocolos?',opts:[['Casi todo es informal o empírico',1],['Algunos procesos poco aplicados',2],['Varios documentados y en uso',3],['Claros, auditados y actualizados',4]]},
    {dim:'Desarrollo',q:'¿Se invierte en capacitación profesional?',opts:[['No hay política de formación',1],['Esporádica y sin planificación',2],['Plan de formación básico',3],['Programa robusto de desarrollo',4]]},
  ]
};
const dAreas=[
  {key:'empresa',   label:'Empresa',   icon:'fa-industry'},
  {key:'deporte',   label:'Deporte',   icon:'fa-trophy'},
  {key:'organismo', label:'Organismo', icon:'fa-university'},
];
let dArea=null,dStep=0,dAnswers=[];
 
(function(){
  const c=document.getElementById('d-area-grid');
  dAreas.forEach(a=>{
    const btn=document.createElement('button'); btn.className='d-area-btn';
    btn.innerHTML=`<i class="fas ${a.icon}"></i><span>${a.label}</span>`;
    btn.onclick=()=>{
      document.querySelectorAll('.d-area-btn').forEach(b=>b.classList.remove('selected'));
      btn.classList.add('selected');dArea=a.key;
      document.getElementById('d-next-0').disabled=false;
    };
    c.appendChild(btn);
  });
})();
 
function dNext(){
  if(dStep===0){dLoadQ(1);dShow(1);}
  else if(dStep>=1&&dStep<=4){dLoadQ(dStep+1);dShow(dStep+1);}
  else if(dStep===5){dResult();dShow(6);}
  dStep=Math.min(dStep+1,6);dUpdateProg();
}
function dBack(){dStep=Math.max(dStep-1,0);dShow(dStep);dUpdateProg();}
function dShow(n){document.querySelectorAll('.d-step').forEach(s=>s.classList.remove('active'));document.getElementById('ds-'+n).classList.add('active');}
function dUpdateProg(){
  document.getElementById('d-fill').style.width=Math.round((dStep/6)*100)+'%';
  const lbl=['Seleccioná tu área','Dimensión 1/5','Dimensión 2/5','Dimensión 3/5','Dimensión 4/5','Dimensión 5/5','Listo'];
  document.getElementById('d-meta-label').textContent=lbl[dStep]||'';
  document.getElementById('d-meta-count').textContent=(dStep+1)+' / 7';
}
function dLoadQ(n){
  const q=dQs[dArea][n-1];
  document.getElementById('d-dlabel-'+n).textContent='Dimensión '+n+': '+q.dim;
  document.getElementById('d-q-'+n).textContent=q.q;
  const c=document.getElementById('d-opts-'+n);c.innerHTML='';
  q.opts.forEach(([label,score])=>{
    const b=document.createElement('button');b.className='d-opt';b.textContent=label;
    b.onclick=()=>{c.querySelectorAll('.d-opt').forEach(x=>x.classList.remove('selected'));b.classList.add('selected');dAnswers[n-1]=score;document.getElementById('d-next-'+n).disabled=false;};
    c.appendChild(b);
  });
  document.getElementById('d-next-'+n).disabled=true;
}
function dResult(){
  const qs=dQs[dArea];
  const total=dAnswers.reduce((a,b)=>a+b,0);
  const pct=Math.round((total/(qs.length*4))*100);
  let nivel,fg,recos;
  if(pct<=40)     {nivel='Estadio inicial';         fg='#F09595';recos=['Tu organización requiere intervención estructural. Los procesos informales generan pérdida de energía sistémica.','La resistencia al cambio es probablemente alta. La Inmersión Profunda puede identificar los cuellos de botella biológicos y organizacionales.','Comenzar por la dimensión más débil genera tracción rápida y confianza institucional.'];}
  else if(pct<=65){nivel='En desarrollo';           fg='#EF9F27';recos=['Bases sólidas pero con focos de fuga energética. La inconsistencia en liderazgo limita el potencial.','Un proceso de alineación de OKRs puede impactar de forma inmediata en productividad.','El trabajo en clima y cohesión destraba resistencias que frenan la implementación.'];}
  else if(pct<=85){nivel='Alto rendimiento parcial';fg='#85B7EB';recos=['Tu organización tiene capacidad real de alto rendimiento pero hay dimensiones que frenan el techo de excelencia.','Optimizar los puntos débiles puede generar un salto exponencial en eficiencia.','Momento ideal para implementar estándares ISO y profesionalizar la gestión.'];}
  else            {nivel='Excelencia';              fg='#D4AF37';recos=['Tu organización opera en nivel de alto rendimiento. El desafío: mantener y escalar la excelencia.','Una auditoría estratégica puede identificar las próximas palancas de crecimiento.','Expandir buenas prácticas hacia áreas o instituciones aliadas.'];}
  const colors=['#D4AF37','#85B7EB','#EF9F27','#F09595','#9FE1CB'];
  let html=`<div style="text-align:center;margin-bottom:20px;">
    <div class="d-score-big" style="color:${fg}">${pct}%</div>
    <span class="d-nivel-badge" style="background:rgba(255,255,255,0.04);color:${fg};border:1px solid ${fg}44;">${nivel}</span>
  </div>
  <div style="margin-bottom:16px;">`;
  qs.forEach((q,i)=>{
    const p=Math.round((dAnswers[i]||0)/4*100);
    html+=`<div class="d-bar-row"><div class="d-bar-label">${q.dim}</div><div class="d-bar-bg"><div class="d-bar-fill" style="width:${p}%;background:${colors[i]}"></div></div><div class="d-bar-val">${p}%</div></div>`;
  });
  html+=`</div><div style="margin-bottom:20px;">`;
  recos.forEach(r=>{html+=`<div class="d-reco">${r}</div>`;});
  html+=`</div>
  <a href="https://wa.me/5493434164699" target="_blank" class="btn-gold"><i class="fab fa-whatsapp" style="margin-right:8px;"></i>Consultar con Fabricio</a>
  <button onclick="dReset()" class="btn-outline">Hacer de nuevo</button>`;
  document.getElementById('d-result').innerHTML=html;
}
function dReset(){
  dArea=null;dStep=0;dAnswers=[];
  document.querySelectorAll('.d-area-btn').forEach(b=>b.classList.remove('selected'));
  document.getElementById('d-next-0').disabled=true;
  document.getElementById('d-fill').style.width='14%';
  document.getElementById('d-meta-label').textContent='Seleccioná tu área';
  document.getElementById('d-meta-count').textContent='1 / 7';
  dShow(0);
}
</script>
