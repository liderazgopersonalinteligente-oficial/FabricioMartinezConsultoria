    <div id="r-sliders-container"></div>
 
    <div class="r-metrics-row">
      <div class="r-metric">
        <span class="val" id="r-global-val">—</span>
        <span class="lbl">Global</span>
        <span class="sub">/ 100</span>
      </div>
